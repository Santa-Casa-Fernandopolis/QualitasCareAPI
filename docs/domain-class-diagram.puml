  KitProcedimento "0..*" --> "1" Tenant
  KitVersion "0..*" --> "1" KitProcedimento
  KitItem "0..*" --> "1" KitVersion
  KitItem "0..*" --> "1" Instrumento
  Instrumento "0..*" --> "1" Tenant
  ExameCultura "0..*" --> "1" Tenant
  ExameCultura "0..*" --> "1" User : registradoPor
  ExameCultura "0..*" --> "0..*" EvidenciaArquivo
