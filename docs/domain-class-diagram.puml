@startuml QualitasCareAPI - Domain Class Diagram
!theme plain
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam shadowing false
skinparam class {
  BackgroundColor White
  BorderColor #555
  ArrowColor #333
}
skinparam package {
  BorderColor #888
  FontStyle bold
}

' ============================================================
' INTERFACES / ABSTRAÇÕES
' ============================================================

interface ApprovableTarget {
}

interface NaoConformidadeBase {
  +getId() : Long
  +getTenant() : Tenant
  +getTitulo() : String
  +getStatus() : NaoConformidadeStatus
  +getTipo() : TipoNaoConformidade
}

' ============================================================
' MÓDULO: IAM
' ============================================================

package "IAM" #E8F4FD {

  class Tenant {
    -id : Long
    -code : String
    -name : String
    -cnpj : String
    -logo : String
    -active : boolean
  }

  class User {
    -id : Long
    -username : String
    -passwordHash : String
    -fullName : String
    -department : String
    -status : UserStatus
    -origin : IdentityOrigin
    -createdAt : LocalDateTime
    -activatedAt : LocalDateTime
    -expiresAt : LocalDateTime
    -updatedAt : LocalDateTime
  }

  class Setor {
    -id : Long
    -nome : String
    -tipo : TipoSetor
    -descricao : String
  }

  class OrgRoleAssignment {
    -id : Long
    -roleType : OrgRoleType
    -active : Boolean
    -vigencia : PeriodoVigencia
  }

  enum UserStatus {
    ACTIVE
    INACTIVE
    SUSPENDED
  }

  enum IdentityOrigin {
    LOCAL
    LDAP
    SSO
  }

  enum TipoSetor {
    CME
    UTI
    CC
    AMBULATORIO
    ADMINISTRATIVO
  }

  enum OrgRoleType {
    GERENTE
    SUPERVISOR
    OPERADOR
    AUDITOR
  }

  Tenant "1" -- "0..*" User
  Tenant "1" -- "0..*" Setor
  OrgRoleAssignment "0..*" --> "1" Tenant
  OrgRoleAssignment "0..*" --> "1" User
  OrgRoleAssignment "0..*" --> "0..1" Setor
  User ..> UserStatus
  User ..> IdentityOrigin
  Setor ..> TipoSetor
  OrgRoleAssignment ..> OrgRoleType
}

' ============================================================
' MÓDULO: SECURITY
' ============================================================

package "Security" #FDF0E8 {

  class Role {
    -id : Long
    -name : String
    -description : String
  }

  class Permission {
    -id : Long
    -resource : ResourceType
    -action : Action
    -feature : String
    -code : String
  }

  class Policy {
    -id : Long
    -resource : ResourceType
    -action : Action
    -feature : String
    -effect : Effect
    -enabled : boolean
    -priority : int
    -description : String
  }

  class PolicyCondition {
    -id : Long
    -type : String
    -operator : String
    -value : String
  }

  class RolePermission {
    -id : Long
  }

  class UserPermissionOverride {
    -id : Long
    -resource : ResourceType
    -action : Action
    -feature : String
    -effect : Effect
    -priority : int
    -reason : String
    -validFrom : LocalDateTime
    -validUntil : LocalDateTime
    -requestedAt : LocalDateTime
    -approvedAt : LocalDateTime
  }

  enum Effect {
    ALLOW
    DENY
  }

  Role "0..*" --> "1" Tenant
  Permission "0..*" --> "1" Tenant
  Policy "0..*" --> "1" Tenant
  Policy "1" *-- "0..*" PolicyCondition
  Policy "0..*" --> "0..*" Role
  RolePermission "0..*" --> "1" Role
  RolePermission "0..*" --> "1" Permission
  RolePermission "0..*" --> "1" Tenant
  User "0..*" --> "0..*" Role
  UserPermissionOverride "0..*" --> "1" User
  UserPermissionOverride "0..*" --> "1" Tenant
  UserPermissionOverride "0..*" --> "0..1" Setor
  UserPermissionOverride "0..*" --> "0..1" User : requestedBy
  UserPermissionOverride "0..*" --> "0..1" User : approvedBy
  UserPermissionOverride ..|> ApprovableTarget
  Policy ..> Effect
  UserPermissionOverride ..> Effect
}

' ============================================================
' MÓDULO: COMMON
' ============================================================

package "Common" #F0F8E8 {

  class EvidenciaArquivo {
    -id : Long
    -nomeArquivo : String
    -uri : String
    -hashSha256 : String
    -contentType : String
    -tamanhoBytes : Long
    -criadoEm : LocalDateTime
  }

  EvidenciaArquivo "0..*" --> "1" Tenant
  EvidenciaArquivo "0..*" --> "1" User : autor
}

' ============================================================
' MÓDULO: CORE (Kit / Instrumento)
' ============================================================

